# ═══════════════════════════════════════════════════════════════
# .env.example — Plantilla de variables de entorno
#
# Uso: copiar este archivo como .env y completar con valores reales
#      cp .env.example .env    (o Copy-Item en PowerShell)
#
# El .env es específico de CADA desarrollador / ambiente.
# Nunca debe subirse a git.
# ═══════════════════════════════════════════════════════════════

# ─── Maximo API (PRODUCCIÓN por defecto) ───────────────────────
MAXIMO_BASE_URL=http://host-maximo-prod:8001/maximo/oslc/os
MAXIMO_CI_URL=http://host-maximo-prod:8001/maximo/oslc/os/MXCI
MAXIMO_USER=tu_usuario
MAXIMO_PASSWORD=tu_password
MAXIMO_TIMEOUT=30

─── DESARROLLO (alternativa — reemplazar las 3 lineas de arriba)
Descomentar y usar estos valores si trabajas contra el ambiente dev:

MAXIMO_BASE_URL=http://10.80.123.13:8001/maximo/oslc/os
MAXIMO_CI_URL=http://10.80.123.13:8001/maximo/oslc/os/MXCI
MAXIMO_USER=restusr
MAXIMO_PASSWORD=restusr2023

# ─── Maximo Oracle DB ──────────────────────────────────────────
ORACLE_USER=tu_usuario_oracle
ORACLE_PSW=tu_password_oracle
ORACLE_DSN=host:puerto/servicio

# ─── MySQL (bot_gesfo) ─────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_NAME=bot_gesfo
DB_USER=tu_usuario_mysql
DB_PASSWORD=tu_password_mysql

# ─── PostgreSQL (opcional) ─────────────────────────────────────
PG_HOST=localhost
PG_PORT=5432
PG_USER=postgres
PG_PASSWORD=
PG_DATABASE=disponibilidad

# ─── Telegram ──────────────────────────────────────────────────
TELEGRAM_TOKEN=tu_token_del_bot
ADMIN_CHAT_ID=tu_chat_id

# ─── PTM ───────────────────────────────────────────────────────
PTM_USER=tu_usuario_ptm
PTM_PASSWORD=tu_password_ptm

# ─── ROSE ──────────────────────────────────────────────────────
ROSE_USER=tu_usuario_rose
ROSE_PASSWORD=tu_password_rose